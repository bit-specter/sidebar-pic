{
  "name": "sidebar-pic",
  "displayName": "Sidebar Pic: Mood Booster",
  "publisher": "MEISDeveloper",
  "version": "0.0.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/bit-specter/sidebar-pic"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.107.1"
  },
  "contributes": {
    "commands": [
      {
        "command": "sidebarPic.setTitle",
        "title": "Sidebar Pic: Set Title"
      },
      {
        "command": "sidebarPic.setImageUrl",
        "title": "Sidebar Pic: Set Image URL"
      },
      {
        "command": "sidebarPic.selectLocalImage",
        "title": "Sidebar Pic: Select Local Image"
      },
      {
        "command": "sidebarPic.clearLocalImage",
        "title": "Sidebar Pic: Clear Local Image"
      }
    ],
    "configuration": {
      "title": "Sidebar Pic Settings",
      "properties": {
        "sidebarPic.title": {
          "type": "string",
          "default": "MY PHOTO",
          "description": "Title shown in the Explorer sidebar section."
        },
        "sidebarPic.imageUrl": {
          "type": "string",
          "default": "https://images.unsplash.com/photo-1517694712202-14dd9538aa97",
          "description": "Image URL to display in the sidebar."
        },
        "sidebarPic.localImagePath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Local image path. You can type it manually, or click [Browse image](command:sidebarPic.selectLocalImage) to choose a file from Explorer. To use URL mode again, click [Clear local image](command:sidebarPic.clearLocalImage). When this value is set, it takes priority over `sidebarPic.imageUrl`."
        }
      }
    },
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "sidebarPicView",
          "name": "PHOTO", 
          "icon": "$(camera)"
        }
      ]
    }
  },
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.107.1",
    "typescript": "^5.9.3"
  }
}